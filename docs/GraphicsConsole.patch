# GraphicsConsole.c — Narrow Screen Fix (480px portrait)
#
# File: edk2/MdeModulePkg/Universal/Console/GraphicsConsoleDxe/GraphicsConsole.c
# Function: InitializeGraphicsConsoleTextMode()
# Lines: ~239-290
#
# Problem: 480/8 = 60 columns < 80.  The original code:
#   1. ASSERT(MaxColumns >= 80) — crashes DEBUG builds
#   2. DeltaX = (480 - 80*8) >> 1 = -80 — underflows to 0xFFFFFFB0
#      causing HiiDatabase buffer overflow when rendering text at huge X offset
#
# Fixes:
#   1. Replace ASSERT with DEBUG_WARN for narrow screens
#   2. Use signed INT32 for DeltaX calculation, clamp negative results to 0
#   3. Always provide >= 2 text modes (prevents null mode access)

--- a/MdeModulePkg/Universal/Console/GraphicsConsoleDxe/GraphicsConsole.c
+++ b/MdeModulePkg/Universal/Console/GraphicsConsoleDxe/GraphicsConsole.c
@@ -239,9 +239,12 @@
   //
-  // According to UEFI spec, all output devices support at least 80x25 text mode.
+  // UEFI spec says 80x25 minimum.  Narrow screens (e.g. 480px portrait)
+  // keep 80 columns for compatibility but clamp DeltaX to 0.
   //
-  ASSERT ((MaxColumns >= 80) && (MaxRows >= 25));
+  if (MaxColumns < 80) {
+    DEBUG ((DEBUG_WARN, "GraphicsConsole: narrow screen %dx%d — only %d cols fit\n",
+            HorizontalResolution, VerticalResolution, MaxColumns));
+  }

@@ -271,18 +274,21 @@
-  NewModeBuffer[ValidCount].Columns       = 80;
-  NewModeBuffer[ValidCount].Rows          = 25;
-  NewModeBuffer[ValidCount].GopWidth      = HorizontalResolution;
-  NewModeBuffer[ValidCount].GopHeight     = VerticalResolution;
-  NewModeBuffer[ValidCount].GopModeNumber = GopModeNumber;
-  NewModeBuffer[ValidCount].DeltaX        = (HorizontalResolution - (NewModeBuffer[ValidCount].Columns * EFI_GLYPH_WIDTH)) >> 1;
-  NewModeBuffer[ValidCount].DeltaY        = (VerticalResolution - (NewModeBuffer[ValidCount].Rows * EFI_GLYPH_HEIGHT)) >> 1;
+  {
+    INT32 dx, dy;
+    NewModeBuffer[ValidCount].Columns       = 80;
+    NewModeBuffer[ValidCount].Rows          = 25;
+    NewModeBuffer[ValidCount].GopWidth      = HorizontalResolution;
+    NewModeBuffer[ValidCount].GopHeight     = VerticalResolution;
+    NewModeBuffer[ValidCount].GopModeNumber = GopModeNumber;
+    dx = ((INT32)HorizontalResolution - (INT32)(80 * EFI_GLYPH_WIDTH)) >> 1;
+    dy = ((INT32)VerticalResolution   - (INT32)(25 * EFI_GLYPH_HEIGHT)) >> 1;
+    NewModeBuffer[ValidCount].DeltaX = (dx < 0) ? 0 : (UINT32)dx;
+    NewModeBuffer[ValidCount].DeltaY = (dy < 0) ? 0 : (UINT32)dy;
+  }
   ValidCount++;

   if ((MaxColumns >= 80) && (MaxRows >= 50)) {
     NewModeBuffer[ValidCount].Columns = 80;
     NewModeBuffer[ValidCount].Rows    = 50;
-    NewModeBuffer[ValidCount].DeltaX  = (HorizontalResolution - (80 * EFI_GLYPH_WIDTH)) >> 1;
-    NewModeBuffer[ValidCount].DeltaY  = (VerticalResolution - (50 * EFI_GLYPH_HEIGHT)) >> 1;
+    NewModeBuffer[ValidCount].DeltaX  = (HorizontalResolution - (80 * EFI_GLYPH_WIDTH)) >> 1;
+    NewModeBuffer[ValidCount].DeltaY  = (VerticalResolution - (50 * EFI_GLYPH_HEIGHT)) >> 1;
+    NewModeBuffer[ValidCount].GopWidth      = HorizontalResolution;
+    NewModeBuffer[ValidCount].GopHeight     = VerticalResolution;
+    NewModeBuffer[ValidCount].GopModeNumber = GopModeNumber;
+    ValidCount++;
+  } else {
+    // Narrow screen: always provide at least 2 modes
+    NewModeBuffer[ValidCount].Columns       = 80;
+    NewModeBuffer[ValidCount].Rows          = 25;
+    NewModeBuffer[ValidCount].GopWidth      = HorizontalResolution;
+    NewModeBuffer[ValidCount].GopHeight     = VerticalResolution;
+    NewModeBuffer[ValidCount].GopModeNumber = GopModeNumber;
+    NewModeBuffer[ValidCount].DeltaX        = 0;
+    NewModeBuffer[ValidCount].DeltaY        = 0;
+    ValidCount++;
+  }
