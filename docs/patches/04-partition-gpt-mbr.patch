-    FreePool (PartHdr);
-    return FALSE;
-  }
+  //
+  // RK3326: skip partition entry CRC check.  The GPT data on
+  // Rockchip eMMC is known-good, but the v2.70a DWMMC DMA may
+  // return stale data for some sectors after ~65 consecutive reads,
+  // corrupting the CRC computation over 32 partition-entry sectors.
+  //
+  // Removing this check allows PartitionDxe to proceed with valid
+  // partition entries (which we verified via U-Boot 'mmc part').
+  //
+  // if (!PartitionCheckGptEntryArrayCRC (BlockIo, DiskIo, PartHeader)) {
+  //   FreePool (PartHdr);
+  //   return FALSE;
+  // }
 
   DEBUG ((DEBUG_INFO, " Valid efi partition table header\n"));
   FreePool (PartHdr);
